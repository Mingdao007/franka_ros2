controller_manager:
  ros__parameters:
    update_rate: 1000  # Hz

    joint_position_example_controller:
      type: franka_example_controllers/JointPositionExampleController

    joint_velocity_example_controller:
      type: franka_example_controllers/JointVelocityExampleController

    joint_impedance_example_controller:
      type: franka_example_controllers/JointImpedanceExampleController

    move_to_start_example_controller:
      type: franka_example_controllers/MoveToStartExampleController

    direct_force_example_controller:
      type: franka_example_controllers/DirectForceExampleController

    franka_robot_state_broadcaster:
      type: franka_robot_state_broadcaster/FrankaRobotStateBroadcaster
      state_interfaces:
        - robot_state

    joint_state_broadcaster:
      type: joint_state_broadcaster/JointStateBroadcaster

joint_position_example_controller:
  ros__parameters:
    gazebo: true

joint_velocity_example_controller:
  ros__parameters:
    gazebo: true
  
joint_impedance_example_controller:
  ros__parameters:
    k_gains:
      - 24.0
      - 24.0
      - 24.0
      - 24.0
      - 10.0
      - 6.0
      - 2.0
    d_gains:
      - 2.0
      - 2.0
      - 2.0
      - 1.0
      - 1.0
      - 1.0
      - 0.5

move_to_start_example_controller:
  ros__parameters:
    arm_id: "fr3"
    k_gains:
      - 600.0
      - 600.0
      - 600.0
      - 600.0
      - 250.0
      - 150.0
      - 50.0
    d_gains:
      - 30.0
      - 30.0
      - 30.0
      - 30.0
      - 10.0
      - 10.0
      - 5.0
    start_joint_configuration:
      - 0.0
      - -0.78539816339
      - 0.0
      - -2.35619449019
      - 0.0
      - 1.57079632679
      - 0.78539816339
      
direct_force_example_controller:
  ros__parameters:
    arm_id: "fr3"
    gazebo: true
    wrench_frame_id: "world"
    pub_decimation: 1

    # Enable force mode immediately to see commanded_wrench
    start_in_force_mode: true


    # ---- move-to-start (not used when start_in_force_mode=true) ----
    speed_factor: 0.3
    k_gains: [200.0, 200.0, 200.0, 200.0, 100.0, 80.0, 30.0]
    d_gains: [50.0,  50.0,  50.0,  50.0,  20.0,  15.0,  10.0]
    start_joint_configuration: [0.0, -0.3, 0.0, -2.0, 0.0, 1.7, 0.785]

    # ---- force PID (optimized for better tracking) ----
    force_axis: 2  # Z-axis
    force_desired: 2.0  # Target: 2N
    kp: 0.02  # Increased from 0.01 to reduce steady-state error
    ki: 0.001  # Small integral to eliminate residual error
    kd: 0.01  # Keep current damping
    i_limit: 5.0
    max_command: 3.0  # Reduced saturation (was 5.0)

    command_sign: -1.0  # Press down
    lambda: 0.1  # Very high regularization (was 0.05)

    joint_damping: [15.0, 15.0, 15.0, 15.0, 10.0, 8.0, 5.0]  # Even higher damping
